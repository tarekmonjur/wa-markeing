# ============================================================
# WA Marketing — Environment Variables
# ============================================================
# For Docker: env vars are set in docker-compose.yml, this file is NOT needed.
# For local dev (without Docker apps): copy to .env and adjust as needed.
# ============================================================

NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://wa_user:wa_pass@localhost:5432/wa_marketing

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-very-long-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wa-media
MINIO_USE_SSL=false

# Session Manager
SESSION_FILES_PATH=./sessions

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OpenAI (optional — used in Phase 3)
OPENAI_API_KEY=
